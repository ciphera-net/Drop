# * Supabase Configuration
# * Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# * Database Configuration (for migrations)
# * Format: postgres://postgres:[YOUR-PASSWORD]@[HOST]:6543/postgres
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:6543/postgres

# * Email Configuration (Resend)
# * Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE

# * Cron Job Security
# * Generate a secure random string for protecting cron endpoints
# * Example: openssl rand -base64 32
CRON_SECRET=YOUR_SECURE_RANDOM_STRING_HERE

# * Application URL
# * Use http://localhost:3000 for development
# * Use your production domain for deployment (e.g., https://drop.example.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# * Optional: Slack Monitoring
# * Create a webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
